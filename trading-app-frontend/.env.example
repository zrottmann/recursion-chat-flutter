# Appwrite Configuration
REACT_APP_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
REACT_APP_APPWRITE_PROJECT_ID=your_project_id_here
REACT_APP_APPWRITE_API_KEY=your_api_key_here

# Database Configuration
REACT_APP_APPWRITE_DATABASE_ID=trading_post_db

# Collection IDs
REACT_APP_APPWRITE_USERS_COLLECTION_ID=users
REACT_APP_APPWRITE_ITEMS_COLLECTION_ID=items
REACT_APP_APPWRITE_WANTS_COLLECTION_ID=wants
REACT_APP_APPWRITE_TRADES_COLLECTION_ID=trades
REACT_APP_APPWRITE_MESSAGES_COLLECTION_ID=messages
REACT_APP_APPWRITE_REVIEWS_COLLECTION_ID=reviews
REACT_APP_APPWRITE_NOTIFICATIONS_COLLECTION_ID=notifications

# Storage Bucket IDs
REACT_APP_APPWRITE_ITEM_IMAGES_BUCKET_ID=item_images
REACT_APP_APPWRITE_PROFILE_IMAGES_BUCKET_ID=profile_images
REACT_APP_APPWRITE_CHAT_ATTACHMENTS_BUCKET_ID=chat_attachments

# OAuth Configuration
REACT_APP_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback
REACT_APP_OAUTH_ERROR_URL=http://localhost:3000/auth/error

# Optional OAuth Providers (Google, GitHub, Facebook are enabled by default)
REACT_APP_ENABLE_MICROSOFT_AUTH=false
REACT_APP_ENABLE_DISCORD_AUTH=false
REACT_APP_ENABLE_APPLE_AUTH=false

# Optional Features
REACT_APP_ENABLE_PHONE_AUTH=false
REACT_APP_ENABLE_MAGIC_LINK=false
REACT_APP_ENABLE_ANONYMOUS_AUTH=false
REACT_APP_ENABLE_BIOMETRIC=false
REACT_APP_ENABLE_MFA=false
REACT_APP_ENABLE_PASSWORDLESS=false

# Security
REACT_APP_ENABLE_CAPTCHA=false
REACT_APP_CAPTCHA_SITE_KEY=

# Analytics (Optional)
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_GA_ID=
REACT_APP_MIXPANEL_TOKEN=

# API Configuration
REACT_APP_API_URL=http://localhost:5000

# Cookie Configuration (Production)
REACT_APP_COOKIE_DOMAIN=
