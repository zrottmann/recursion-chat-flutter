# NPM Configuration for Trading App Frontend
# Force resolution of peer dependencies
legacy-peer-deps=true
force=true

# Ensure npm uses production registry
registry=https://registry.npmjs.org/

# Disable package-lock for cleaner builds
package-lock=false

# Increase network timeout for slower connections
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=300000

# Disable audit to speed up installation
audit=false

# Use exact versions to prevent surprises
save-exact=true

# Max sockets for parallel downloads
maxsockets=10