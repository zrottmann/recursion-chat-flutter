{
  "name": "trading-app-frontend",
  "version": "1.1.0",
  "type": "module",
  "description": "Trading Post - Local community trading app",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "vitest run src/test/e2e-example.test.js",
    "test:e2e:watch": "vitest src/test/e2e-example.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "android:dev": "npm run build && npx cap copy android && npx cap open android",
    "android:build": "npm run build && npx cap copy android && npx cap sync android",
    "android:run": "npm run android:build && npx cap run android",
    "sites:build": "vite build --mode sites",
    "sites:preview": "vite build --mode sites && vite preview"
  },
  "keywords": [
    "trading",
    "community",
    "marketplace"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/keyboard": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@hookform/resolvers": "^5.2.0",
    "@react-oauth/google": "^0.12.2",
    "@reduxjs/toolkit": "^2.8.2",
    "@stripe/react-stripe-js": "^3.9.0",
    "@stripe/stripe-js": "^3.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "appwrite": "^18.2.0",
    "axios": "1.11.0",
    "bootstrap": "^5.3.7",
    "d3": "7.9.0",
    "financejs": "4.1.0",
    "firebase": "^10.14.1",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lightweight-charts": "5.0.8",
    "lucide-react": "0.541.0",
    "plotly.js": "3.1.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-grid-layout": "1.5.2",
    "react-hook-form": "^7.61.1",
    "react-leaflet": "4.2.1",
    "react-plotly.js": "2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.1",
    "react-select": "5.10.2",
    "react-toastify": "^11.0.5",
    "react-tradingview-embed": "3.0.6",
    "vite": "^6.0.2",
    "ws": "8.18.3",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "6.7.0",
    "@testing-library/react": "15.0.7",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "^16.3.0",
    "happy-dom": "18.0.1",
    "puppeteer": "24.16.2",
    "vitest": "3.2.4"
  },
  "overrides": {
    "glob": "^10.4.0",
    "rimraf": "^5.0.0",
    "inflight": "npm:@isaacs/inflight@^1.0.0",
    "semver": "^7.6.0",
    "osenv": "npm:os-env@^1.0.0",
    "@xmldom/xmldom": "^0.8.0",
    "@babel/plugin-proposal-optional-chaining": "npm:@babel/plugin-transform-optional-chaining@^7.24.0",
    "@babel/plugin-proposal-optional-catch-binding": "npm:@babel/plugin-transform-optional-catch-binding@^7.24.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "npm:@babel/plugin-transform-nullish-coalescing-operator@^7.24.0",
    "@babel/plugin-proposal-numeric-separator": "npm:@babel/plugin-transform-numeric-separator@^7.24.0",
    "@babel/plugin-proposal-class-properties": "npm:@babel/plugin-transform-class-properties@^7.24.0",
    "@babel/plugin-proposal-async-generator-functions": "npm:@babel/plugin-transform-async-generator-functions@^7.24.0",
    "@babel/plugin-proposal-logical-assignment-operators": "npm:@babel/plugin-transform-logical-assignment-operators@^7.24.0",
    "@babel/plugin-proposal-object-rest-spread": "npm:@babel/plugin-transform-object-rest-spread@^7.24.0"
  }
}
