# Appwrite Configuration Template for Trading Post
# Copy this file to .env.appwrite.production and fill in the actual values
# NEVER commit .env.appwrite.production to version control

# Appwrite Core Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# Database Configuration
APPWRITE_DATABASE_ID=trading_post_db

# Collection IDs
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_ITEMS_COLLECTION_ID=items
APPWRITE_WANTS_COLLECTION_ID=wants
APPWRITE_TRADES_COLLECTION_ID=trades
APPWRITE_MESSAGES_COLLECTION_ID=messages
APPWRITE_REVIEWS_COLLECTION_ID=reviews
APPWRITE_NOTIFICATIONS_COLLECTION_ID=notifications

# Storage Bucket IDs
APPWRITE_ITEM_IMAGES_BUCKET_ID=item_images
APPWRITE_PROFILE_IMAGES_BUCKET_ID=profile_images
APPWRITE_CHAT_ATTACHMENTS_BUCKET_ID=chat_attachments

# OAuth Provider Configuration
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_GITHUB_CLIENT_ID=your_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# AI Services
OPENAI_API_KEY=your_openai_api_key

# Payment Services
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Environment
ENVIRONMENT=production
FRONTEND_URL=https://trading-post.appwrite.io
API_URL=https://api.trading-post.appwrite.io

# JWT Configuration
SECRET_KEY=generate_a_secure_32_character_minimum_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key

# Feature Flags
ENABLE_SSO=true
ENABLE_EMAIL_AUTH=true
ENABLE_AI_MATCHING=true
ENABLE_PAYMENTS=true

# Security
ENABLE_CSRF=true
ENABLE_RATE_LIMITING=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=INFO