# =======================================================================
# TRADING POST ENVIRONMENT CONFIGURATION - SECURE TEMPLATE
# =======================================================================
# 
# SECURITY NOTICE:
# - This file contains placeholder values for security-sensitive variables
# - Copy this file to .env and replace ALL placeholder values with real ones
# - Never commit your actual .env file with real secrets to version control
# - Use strong, unique values for all secrets and passwords
# 
# =======================================================================

# Appwrite SSO Configuration (REQUIRED)
# Get these from your Appwrite project console
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-appwrite-api-key-here

# Database Configuration
# For local development, use SQLite: sqlite:///./tradingpost.db
# For production, use PostgreSQL with strong credentials
DATABASE_URL=postgresql://username:strong_password@localhost:5432/tradingpost
REDIS_URL=redis://localhost:6379/0

# JWT Configuration (CRITICAL SECURITY)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_32_CHAR_SECURE_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL (for OAuth callbacks)
# Update this to your actual domain in production
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-specific-password

# External APIs (Optional)
GEOCODING_API_KEY=your-geocoding-api-key
MAPS_API_KEY=your-maps-api-key
GROK_API_KEY=your-grok-api-key

# OAuth Configuration (REQUIRED for SSO features)
# Get these from respective OAuth provider consoles
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Admin Configuration (REQUIRED)
# Generate strong password: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=REPLACE_WITH_SECURE_ADMIN_PASSWORD

# ML Model Paths (Optional)
RECOMMENDATION_MODEL_PATH=/app/models/recommendation_model.pkl
PRICE_PREDICTION_MODEL_PATH=/app/models/price_model.pkl

# Feature Flags
ENABLE_ML_RECOMMENDATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_RATE_LIMITING=true

# Performance Configuration
MAX_CONNECTIONS_PER_WORKER=100
WORKER_TIMEOUT=120
CACHE_TTL_SECONDS=300

# Security Configuration
ENV=production
SECURITY_ENABLED=true

# CORS Configuration (Production domains only)
# Add your production domains separated by commas
ADDITIONAL_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =======================================================================
# SECURITY CHECKLIST:
# =======================================================================
# [ ] SECRET_KEY is at least 32 characters long and cryptographically secure
# [ ] ADMIN_PASSWORD is strong and unique
# [ ] All OAuth client secrets are from respective provider consoles
# [ ] Database credentials are strong (if using PostgreSQL)
# [ ] SMTP credentials are app-specific passwords, not main password
# [ ] CORS origins are specific domains, never "*"
# [ ] ENV is set to "production" for production deployments
# [ ] This .env file is added to .gitignore
# =======================================================================