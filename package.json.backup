{
  "name": "tradingpost-backend",
  "version": "1.0.0",
  "description": "Trading Post backend with Python and Node.js frontend build",
  "scripts": {
    "build": "cd trading-app-frontend && npm install --legacy-peer-deps && set CI=false && set TSC_COMPILE_ON_ERROR=true && set DISABLE_ESLINT_PLUGIN=true && npm run build",
    "install": "echo 'Installation complete - no platform deps required'",
    "test": "echo 'No tests specified'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-router": "^7.0.2",
    "react-router-dom": "^7.0.2",
    "@stripe/react-stripe-js": "^3.9.0",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "ajv-formats": "^2.1.1"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "node-appwrite": "^17.2.0"
  },
  "devDependencies": {
    "eslint": "^9.33.0",
    "prettier": "^3.0.0",
    "@eslint/js": "^9.33.0"
  }
}